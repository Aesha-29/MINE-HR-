generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Employee {
  id         Int    @id @default(autoincrement())
  employeeId String @unique

  // Basic Info
  firstName   String?
  middleName  String?
  lastName    String?
  mobile      String?
  dob         DateTime?
  bloodGroup  String?
  gender      String?
  cvUrl       String?
  idProofUrl  String?
  welcomeSent Boolean   @default(false)

  // Job Info
  designation               String?
  designationId             Int?
  designationRef            Designation? @relation(fields: [designationId], references: [id])
  branch                    String?
  branchId                  Int?
  branchRef                 Branch?      @relation(fields: [branchId], references: [id])
  department                String?
  departmentId              Int?
  departmentRef             Department?  @relation(fields: [departmentId], references: [id])
  subDepartment             String?
  grade                     String?
  employeeType              String?
  zone                      String?
  levelId                   Int?
  level                     Level?       @relation(fields: [levelId], references: [id])
  shift                  String?
  email                  String?
  doj                    DateTime?
  probationDays          Int?
  trainingCompletionDate DateTime?
  permanentDate          DateTime?
  sisterCompany          String?
  location               String?

  // Manager Relation
  managerId Int?
  manager   Manager? @relation(fields: [managerId], references: [id])
  managerEffectiveDate DateTime?
  managerRemarks       String?   @db.Text

  insuranceNo      String?
  insuranceCompany String?
  insuranceExpiry  DateTime?
  retirementAge    Int?
  jobDescription   String?   @db.Text

  // Contact Info
  whatsapp         String?
  altPhone         String?
  emergencyNumber  String?
  companyMobile    String?
  currentAddress   String? @db.Text
  permanentAddress String? @db.Text
  personalEmail    String?
  socialLinks      String? @db.Text
  weddingAnniversary DateTime?

  // Other Info
  skills        String? @db.Text
  hobbies       String? @db.Text
  languages     String?
  specialSkills String? @db.Text
  maritalStatus String?
  familyMembers Int?
  nationality   String?

  // Bank Details
  bankHolder  String?
  bankName    String?
  bankBranch  String?
  accountType String?
  accountNo   String?
  ifscCode    String?
  crnNo       String?
  esicNo      String?
  panNo       String?
  pfNo        String?
  uanNo       String?
  micrNo      String?

  // Authentication & RBAC (Feature 16)
  password    String?
  role        String   @default("Employee") // 'Employee', 'HR', 'Admin'

  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  offboardings          Offboarding[]
  levelHistory          LevelHistory[]
  profileChangeRequests ProfileChangeRequest[]
  structureHistory      EmployeeStructureHistory[]
  resignations          Resignation[]
  promotions            Promotion[]
  attendanceLogs        AttendanceLog[]
  payslips              Payslip[]
  leaveBalances           LeaveBalance[]
  leaveRequests           LeaveRequest[]
  shiftAssignments        ShiftAssignment[]
  distributorAssignments  DistributorAssignment[]
  holidayExchangeRequests HolidayExchangeRequest[]
  shiftChangeRequests     ShiftChangeRequest[]

  // Advance Leave Mgt
  employeeLeaveGroups     EmployeeLeaveGroup[]
  autoLeaves              AutoLeave[]
  leavePayoutRequests     LeavePayoutRequest[]
  shortLeaveRequests      ShortLeaveRequest[]

  // Product & Order Management
  beatPlans               BeatPlan[]
  jobLocation             JobLocation?
  dailySalesAggregates    DailySalesAggregate[]
  orders                  Order[]
  employeeRoutes          EmployeeRoute[]
  visitExpenseAssignments VisitExpenseAssignment[]

  // Advance Payments
  advanceSalaries         AdvanceSalary[]
  advanceSalaryRequests   AdvanceSalaryRequest[]

  // Expense Module
  expenseTemplateAssignments  ExpenseTemplateAssignment[]
  expenseEntries              ExpenseEntry[]
  expenseAdvances             ExpenseAdvance[]
  tasks                       Task[]                   @relation("TaskAssignedTo")
  
  // FaceX App
  userFaceData              UserFaceData?
  faceChangeRequests        FaceChangeRequest[]

  // Events
  events                    Event[]                  @relation("EmployeeEvents")
  rsvps                     EventRSVP[]

  // Penalty
  penaltyRecords            PenaltyRecord[]

  // Assets
  assets                    Asset[]
  assetSetting             AssetSetting?

  // Nominees
  nominees                  EmployeeNominee[]

  // Lost & Found
  reportedLostItems         LostFoundItem[]
  claims                    ItemClaim[] @relation("ClaimedBy")
  approvedClaims            ItemClaim[] @relation("ApprovedBy")
  surveyResponses           SurveyResponse[]
}

model ExEmployee {
  id         Int    @id @default(autoincrement())
  employeeId String

  // Matching fields to save data
  firstName   String?
  middleName  String?
  lastName    String?
  email       String?
  mobile      String?
  designation String?
  department  String?
  branch      String?

  exitDate          DateTime?
  reason            String?
  eligibleForRehire Boolean?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Manager {
  id         Int        @id @default(autoincrement())
  name       String?
  email      String?
  mobile     String?
  department String?
  branch     String?
  level      String? // Manager, Senior Manager, Team Lead
  
  // Authentication & RBAC (Feature 16)
  password   String?
  role       String   @default("Manager") // 'Manager'

  active     Boolean?   @default(true)
  employees  Employee[]
  faceAppAdmins FaceAppAdmin[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Offboarding {
  id              Int       @id @default(autoincrement())
  employeeId      Int
  employee        Employee  @relation(fields: [employeeId], references: [id])
  lastWorkingDate DateTime?
  reason          String?
  status          String    @default("Pending") // Pending / Completed

  checklists ExitChecklist[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExitChecklist {
  id             Int         @id @default(autoincrement())
  offboardingId  Int
  offboarding    Offboarding @relation(fields: [offboardingId], references: [id])
  department     String // HR, IT, Admin, Finance
  taskName       String
  assignedTo     String? // Email or ID of responsible person
  status         String      @default("Pending") // Pending / Completed
  completionDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Finance {
  id         Int      @id @default(autoincrement())
  employeeId String
  salary     Float?
  bonus      Float?
  deductions Float?
  month      String?
  year       Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Onboarding {
  id                 Int      @id @default(autoincrement())
  employeeId         String
  documentsSubmitted Boolean?
  trainingCompleted  Boolean?
  orientationDone    Boolean?
  status             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Level {
  id             Int     @id @default(autoincrement())
  levelName      String  @unique
  levelCode      String?
  description    String? @db.Text
  parentLevelId  Int?
  parentLevel    Level?  @relation("LevelHierarchy", fields: [parentLevelId], references: [id])
  subLevels      Level[] @relation("LevelHierarchy")
  hierarchyOrder Int?
  status         String  @default("Active")

  employees    Employee[]
  levelHistory LevelHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LevelHistory {
  id            Int       @id @default(autoincrement())
  employeeId    Int
  employee      Employee  @relation(fields: [employeeId], references: [id])
  levelId       Int
  level         Level     @relation(fields: [levelId], references: [id])
  effectiveFrom DateTime
  effectiveTo   DateTime?
  remarks       String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProfileChangeRequest {
  id         Int      @id @default(autoincrement())
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])
  changeType String // 'Personal Info', 'Contact Info', 'Bank Details', etc.
  oldData    Json?
  newData    Json
  riskLevel  String // 'Low', 'Medium', 'High'
  status     String   @default("Pending") // 'Pending', 'Approved', 'Rejected'

  reviewedBy      Int? // User ID of HR/Admin who reviewed it
  rejectionReason String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -------------------------------------------------------------
// Structure Management
// -------------------------------------------------------------

model Branch {
  id         Int      @id @default(autoincrement())
  branchName String   @unique
  branchCode String?
  address    String?  @db.Text
  city       String?
  state      String?
  status     String   @default("Active") // 'Active', 'Inactive'
  
  employees Employee[]
  devices   Device[]
  faceAppDevices FaceAppDevice[]
  expenseSettings ExpenseSetting[]
  ledgerTransactions LedgerTransaction[]
  branchEvents       Event[] @relation("BranchEvents")
  assets             Asset[] @relation("BranchAssets")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id             Int      @id @default(autoincrement())
  departmentName String   @unique
  departmentCode String?
  description    String?  @db.Text
  status         String   @default("Active")

  employees Employee[]
  expenseSettings ExpenseSetting[]
  departmentEvents Event[] @relation("DepartmentEvents")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Designation {
  id              Int      @id @default(autoincrement())
  designationName String   @unique
  designationCode String?
  description     String?  @db.Text
  status          String   @default("Active")

  employees Employee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Device {
  id                    Int      @id @default(autoincrement())
  deviceName            String
  deviceId              String   @unique
  branchId              Int
  branch                Branch   @relation(fields: [branchId], references: [id])
  locationName          String?
  ipAddress             String?
  status                String   @default("Active")
  departmentRestriction Int? // Restrict swipe to a specific departmentID (Optional)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmployeeStructureHistory {
  id            Int      @id @default(autoincrement())
  employeeId    Int
  employee      Employee @relation(fields: [employeeId], references: [id])
  
  transferType  String   // 'Branch', 'Department', 'Designation'
  oldValueId    Int?     // Before ID
  newValueId    Int      // After ID
  effectiveDate DateTime
  remarks       String?  @db.Text
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Resignation {
  id              Int       @id @default(autoincrement())
  employeeId      Int
  employee        Employee  @relation(fields: [employeeId], references: [id])
  resignationDate DateTime  @default(now())
  lastWorkingDate DateTime?
  noticePeriod    Int?
  reason          String?   @db.Text
  status          String    @default("Pending") // 'Pending', 'Approved', 'Rejected'
  remarks         String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Promotion {
  id              Int       @id @default(autoincrement())
  employeeId      Int
  employee        Employee  @relation(fields: [employeeId], references: [id])
  previousDesignation String?
  newDesignation  String
  previousLevelId Int?
  newLevelId      Int?
  promotionDate   DateTime
  salaryIncrement Float?    
  remarks         String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -------------------------------------------------------------
// Leave Management System (Feature 15)
// -------------------------------------------------------------

model LeaveType {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  leaveCode       String?  @unique
  description     String?  @db.Text
  defaultDays     Int      @default(0)
  isPaid          Boolean  @default(true)
  carryForward    Boolean  @default(false)
  encashAllowed   Boolean  @default(false)
  docRequired     Boolean  @default(false)
  status          String   @default("Active")

  // Advanced Applicability Rules
  applyOnWeeklyOff        Boolean @default(false)
  applyOnHoliday          Boolean @default(false)
  applicableInUnpaidLeave Boolean @default(false)
  applicableFor           String  @default("All") // "All", "Men", "Women", "Married", "Unmarried", "Married Female Only", "Married Male Only"
  isBirthdayLeave         Boolean @default(false)
  isAnniversaryLeave      Boolean @default(false)
  applyOnPastDays         Boolean @default(true)

  leaveBalances   LeaveBalance[]
  leaveRequests   LeaveRequest[]
  policies        LeavePolicy[]
  leaveGroupRules LeaveGroupRule[]
  payoutRequests  LeavePayoutRequest[]
  penaltyConversions PenaltyConversion[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model LeavePolicy {
  id              Int       @id @default(autoincrement())
  leaveTypeId     Int
  leaveType       LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  daysPerYear     Int       @default(0)
  maxPerMonth     Int       @default(0)
  accrualType     String    @default("Yearly") // "Yearly" | "Monthly"
  docAfterDays    Int       @default(0)   // require doc if leave > N days
  noticeDays      Int       @default(0)
  carryForwardMax Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([leaveTypeId])
}

model LeaveSettings {
  id                  Int     @id @default(autoincrement())
  sandwichRule        Boolean @default(false)
  minLeaveDays        Float   @default(0.5)
  maxLeaveDays        Int     @default(30)
  noticePeriodDays    Int     @default(1)
  allowCancelBefore   Boolean @default(true)
  allowCancelAfter    Boolean @default(false)
  autoApproveAfterDays Int    @default(0) // 0 = disabled

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LeaveBalance {
  id          Int       @id @default(autoincrement())
  employeeId  Int
  employee    Employee  @relation(fields: [employeeId], references: [id])
  leaveTypeId Int
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])
  total       Float     @default(0)
  used        Float     @default(0)
  pending     Float     @default(0) // Locked balance during review
  
  year        Int       // 2024, 2025

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([employeeId, leaveTypeId, year])
}

model LeaveRequest {
  id          Int       @id @default(autoincrement())
  employeeId  Int
  employee    Employee  @relation(fields: [employeeId], references: [id])
  leaveTypeId Int
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])
  
  startDate   DateTime
  endDate     DateTime
  days        Float     // Allows for half day (0.5)
  reason      String?   @db.Text
  status      String    @default("Pending") // Pending, Approved, Rejected, Cancelled

  leaveReasonId Int?
  leaveReason   LeaveReason? @relation(fields: [leaveReasonId], references: [id])

  reviewedBy  Int?      // ID of manager/HR who reviewed
  reviewDate  DateTime?
  reviewDocs  String?   @db.Text // JSON or comma separated URLs for medical certificates

  approvalLogs LeaveApprovalLog[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// -------------------------------------------------------------
// Attendance Tracking (Feature 17)
// -------------------------------------------------------------

model AttendanceLog {
  id         Int      @id @default(autoincrement())
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])
  
  date       DateTime @db.Date // Specific day of attendance (e.g. 2024-03-03)
  clockIn    DateTime?
  clockOut   DateTime?
  status     String   @default("Present") // 'Present', 'Absent', 'Half Day'
  
  totalHours Float?   // Calculated total hours worked that day
  ipAddress  String?  // Validation of punch location
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([employeeId, date])
}

// -------------------------------------------------------------
// Payroll & Payslips (Feature 18)
// -------------------------------------------------------------

model PayrollRun {
  id              Int       @id @default(autoincrement())
  month           String    // e.g. "January"
  year            Int       // e.g. 2024
  status          String    @default("Draft") // 'Draft', 'Processed', 'Paid'
  totalEmployees  Int       @default(0)
  totalCost       Float     @default(0)
  processedBy     Int?      // Manager ID
  processedAt     DateTime?
  
  payslips        Payslip[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([month, year])
}

// -------------------------------------------------------------
// Bulk Update Audit Logs
// -------------------------------------------------------------

model BulkUpdateBatch {
  id         Int              @id @default(autoincrement())
  updateType String
  status     String           @default("Completed")
  logs       BulkUpdateLog[]
  createdAt  DateTime         @default(now())
}

model BulkUpdateLog {
  id              Int              @id @default(autoincrement())
  batchId         Int
  batch           BulkUpdateBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  employeeId      String
  status          String           // Success, Failed
  changesDetected String?          @db.Text // JSON string of old vs new
  errorMessage    String?          @db.Text
  createdAt       DateTime         @default(now())
}

model Payslip {
  id              Int        @id @default(autoincrement())
  payrollRunId    Int
  payrollRun      PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId      Int
  employee        Employee   @relation(fields: [employeeId], references: [id])
  
  // Salary Breakdown
  basic           Float
  hra             Float
  allowances      Float
  
  // Deductions
  pfDeduction     Float      @default(0)
  esiDeduction    Float      @default(0)
  taxDeduction    Float      @default(0)
  otherDeductions Float      @default(0)

  // Calculations
  grossSalary     Float
  totalDeductions Float
  netSalary       Float
  
  status          String     @default("Generated") // 'Generated', 'Sent'
  paymentDate     DateTime?

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([employeeId, payrollRunId])
}

// -------------------------------------------------------------
// Shift Management (Feature 20)
// -------------------------------------------------------------

model Shift {
  id              Int      @id @default(autoincrement())
  shiftName       String   @unique
  shiftCode       String?  @unique
  department      String?
  description     String?  @db.Text

  // Time
  startTime       String   // "09:00"
  endTime         String   // "18:00"
  totalWorkHours  Float    @default(8)
  breakTime       Float    @default(1)  // hours

  // Late rules
  gracePeriod     Int      @default(10)  // minutes
  lateAfterMin    Int      @default(15)  // late if punched after startTime + lateAfterMin

  // Early leaving
  earlyLeaveAllowed Boolean @default(true)
  earlyLeaveBeforeMin Int  @default(30)  // minutes before endTime

  // Half day / absent
  halfDayHours    Float    @default(4)
  absentIfNoPunchAfterMin Int @default(120) // minutes after startTime

  // Overtime
  overtimeAllowed Boolean  @default(false)
  minOvertimeMin  Int      @default(30)
  maxOvertimeHours Float   @default(4)
  overtimeRateType String? @default("1.5x") // "1x","1.5x","2x"

  // Break
  breakType       String   @default("Fixed") // "Fixed" | "Flexible"
  breakStartTime  String?  // "13:00"
  breakEndTime    String?  // "14:00"

  // Geo-fence
  geoFenceEnabled Boolean  @default(false)
  officeLatitude  Float?
  officeLongitude Float?
  allowedRadiusM  Int?     @default(200)

  // Weekly off config (comma-separated day names e.g. "Saturday,Sunday")
  weeklyOffDays   String?  @default("Sunday")
  halfDayOffDays  String?  // e.g. "Saturday"
  weeklyOffPattern String?  // e.g. "2nd,4th Saturday"

  // Midnight shift support
  nextDayGraceTime Int     @default(0) // minutes

  status          String   @default("Active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignments     ShiftAssignment[]
  rotations       ShiftRotation[]
  changeRequests  ShiftChangeRequest[] @relation("RequestedShift")
  penaltyRules    PenaltyRule[]
  penaltyRecords  PenaltyRecord[]
}

model ShiftAssignment {
  id            Int       @id @default(autoincrement())
  employeeId    Int
  employee      Employee  @relation(fields: [employeeId], references: [id])
  shiftId       Int
  shift         Shift     @relation(fields: [shiftId], references: [id])
  assignedBy    String?   // "Individual" | "Department" | "Team"
  startDate     DateTime
  endDate       DateTime?
  isActive      Boolean   @default(true)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([employeeId, shiftId, startDate])
}

model ShiftRotation {
  id              Int      @id @default(autoincrement())
  rotationName    String
  shiftSequence   String   @db.Text  // JSON array of shiftIds in order
  rotationPeriod  String   @default("Weekly") // "Daily" | "Weekly" | "Monthly"
  cycleStartDate  DateTime
  departmentName  String?
  status          String   @default("Active")
  shiftId         Int?
  shift           Shift?   @relation(fields: [shiftId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// -------------------------------------------------------------
// Holiday Management (Feature 21)
// -------------------------------------------------------------

model Holiday {
  id          Int      @id @default(autoincrement())
  name        String
  date        DateTime @db.Date
  type        String   @default("Public") // Public, Mandatory, Optional
  year        Int
  description String?
  
  assignments HolidayAssignment[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HolidayAssignment {
  id          Int      @id @default(autoincrement())
  holidayId   Int
  holiday     Holiday  @relation(fields: [holidayId], references: [id], onDelete: Cascade)
  targetType  String   // "Company", "Branch", "Department", "Employee"
  targetId    Int?     // Corresponding ID
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HolidayExchangeRequest {
  id              Int      @id @default(autoincrement())
  employeeId      Int
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  originalHolidayId Int
  exchangeDate    DateTime @db.Date
  reason          String?  @db.Text
  status          String   @default("Pending") // Pending, Approved, Rejected
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// -------------------------------------------------------------
// Shift Change Workflow 
// -------------------------------------------------------------

model ShiftChangeRequest {
  id              Int      @id @default(autoincrement())
  employeeId      Int
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  requestedShiftId Int
  requestedShift  Shift    @relation("RequestedShift", fields: [requestedShiftId], references: [id], onDelete: Cascade)
  date            DateTime @db.Date
  reason          String?  @db.Text
  status          String   @default("Pending") // Pending, Approved, Rejected
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// -------------------------------------------------------------
// Shift Penalty Rules
// -------------------------------------------------------------

model ShiftPenaltyRule {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  type         String   // LateComing, EarlyLeaving, MissingPunch, ShortWorkingHours, LateAfterBreak
  thresholdMin Int      @default(0) // minutes after which penalty applies
  deductionAmt Float?   @default(0) // fixed currency deduction
  dayDeduction Float?   @default(0) // partial day deduction (e.g. 0.5)
  status       String   @default("Active")
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// -------------------------------------------------------------
// Advanced Leave Management (Module Additions)
// -------------------------------------------------------------

model LeaveReason {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?  @db.Text
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requests    LeaveRequest[]
}

model LeaveGroup {
  id          Int      @id @default(autoincrement())
  groupName   String   @unique
  description String?  @db.Text

  rules       LeaveGroupRule[]
  employees   EmployeeLeaveGroup[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LeaveGroupRule {
  id              Int        @id @default(autoincrement())
  leaveGroupId    Int
  leaveGroup      LeaveGroup @relation(fields: [leaveGroupId], references: [id], onDelete: Cascade)
  leaveTypeId     Int
  leaveType       LeaveType  @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  totalLeaves     Float      @default(0)
  accrualMethod   String     @default("Yearly") // Yearly, Monthly, Quarterly, Half-Yearly
  
  // Usage Rules
  leaveRestriction       Boolean @default(false)
  allowDuringProbation   Boolean @default(true)
  allowDuringNoticePeriod Boolean @default(true)
  
  // Carry Forward
  carryForwardAllowed    Boolean @default(false)
  maxCarryForwardLimit   Float   @default(0)

  // Payout
  leavePayoutAllowed     Boolean @default(false)
  payoutLimit            Float   @default(0)

  // Application Rules
  minLeaveApply          Float   @default(0.5)
  maxLeaveApply          Float   @default(30)
  allowHalfDayLeave      Boolean @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([leaveGroupId, leaveTypeId])
}

model EmployeeLeaveGroup {
  id             Int        @id @default(autoincrement())
  employeeId     Int
  employee       Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveGroupId   Int
  leaveGroup     LeaveGroup @relation(fields: [leaveGroupId], references: [id], onDelete: Cascade)
  effectiveDate  DateTime   @db.Date

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([employeeId])
}

model LeaveWorkflow {
  id           Int      @id @default(autoincrement())
  level        Int
  approverRole String   // "Reporting Manager", "HR", "Admin"
  branchId     Int?
  departmentId Int?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model LeaveApprovalLog {
  id             Int          @id @default(autoincrement())
  leaveRequestId Int
  leaveRequest   LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)
  approverId     Int
  status         String       // "Approved", "Rejected"
  comment        String?      @db.Text

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model AutoLeave {
  id               Int      @id @default(autoincrement())
  employeeId       Int
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  branchId         Int?     
  departmentId     Int?
  leaveDate        DateTime @db.Date
  dayType          String   // "full", "half", "quarter"
  workingHours     Float    @default(0)
  productiveHours  Float    @default(0)
  punchIn          String?
  punchOut         String?
  reason           String?

