model CelebrationTemplate {
  id           Int      @id @default(autoincrement())
  templateName String
  eventType    String   // Birthday, Work Anniversary, Wedding Anniversary
  message      String   @db.Text
  autoSend     Boolean  @default(false)
  sendVia      String   @default("Email") // Email, WhatsApp, App Notification
  status       String   @default("Active") // Active, Inactive
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// -------------------------------------------------------------
// FaceX App Module
// -------------------------------------------------------------

model FaceAppAdmin {
  id          Int      @id @default(autoincrement())
  managerId   Int
  manager     Manager  @relation(fields: [managerId], references: [id])
  username    String   @unique
  password    String   // Unique login password for the app
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  devices     FaceAppDevice[]
}

model FaceAppDevice {
  id                   Int      @id @default(autoincrement())
  deviceId             String   @unique
  deviceMac            String?  @unique
  type                 String   @default("Mobile") // Mobile / Tablet
  appVersion           String?
  deviceModel          String?
  branchId             Int?
  branch               Branch?  @relation(fields: [branchId], references: [id])
  remark               String?  @db.Text
  lastSyncDate         DateTime?
  adminId              Int?
  admin                FaceAppAdmin? @relation(fields: [adminId], references: [id])
  camera               Boolean  @default(true)
  cameraSteadySeconds  Int      @default(3)
  status               String   @default("Allowed") // Allowed / Blocked
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  faceChangeRequests   FaceChangeRequest[]
}

model UserFaceData {
  id              Int      @id @default(autoincrement())
  employeeId      Int      @unique
  employee        Employee @relation(fields: [employeeId], references: [id])
  photoUrl        String?
  lastUpdatedDate DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model FaceChangeRequest {
  id              Int           @id @default(autoincrement())
  employeeId      Int
  employee        Employee      @relation(fields: [employeeId], references: [id])
  oldPhotoUrl     String?
  newPhotoUrl     String
  deviceId        Int?
  device          FaceAppDevice? @relation(fields: [deviceId], references: [id])
  status          String        @default("Pending") // Pending, Approved, Rejected
  rejectionReason String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model FaceAppSetting {
  id                  Int      @id @default(autoincrement())
  matchingAccuracy    Float    @default(80.0)
  livenessDetection   Boolean  @default(true)
  geoFaceCombo        Boolean  @default(false)
  offlineModeSync     Boolean  @default(true)
  multiFaceCapture    Int      @default(3) // angles
  alertMismatchAttempts Boolean @default(true)
  updatedAt           DateTime @updatedAt
}

model Event {
  id               Int          @id @default(autoincrement())
  eventName        String
  eventType        String       // Meeting, Training, Celebration, Webinar, Other
  startDate        DateTime
  endDate          DateTime
  startTime        String?
  endTime          String?
  locationType     String       // Office, Online
  location         String?      // Venue or Link
  description      String?      @db.Text
  attachmentUrl    String?
  sendNotification Boolean      @default(false)
  allowRSVP        Boolean      @default(false)
  status           String       @default("Upcoming") // Upcoming, Ongoing, Completed, Cancelled
  
  branches         Branch[]     @relation("BranchEvents")
  departments      Department[] @relation("DepartmentEvents")
  employees        Employee[]   @relation("EmployeeEvents")
  rsvps            EventRSVP[]
  albums           GalleryAlbum[] // Added for Company Gallery

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model EventRSVP {
  id         Int      @id @default(autoincrement())
  eventId    Int
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  status     String   // Going, Not Going, Maybe
  remarks    String?  @db.Text
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([eventId, employeeId])
}

// -------------------------------------------------------------
// Penalty Management Module
// -------------------------------------------------------------

model PenaltyRule {
  id                  Int             @id @default(autoincrement())
  ruleName            String          @unique
  applicableOn        String          // Late In, Early Out, Half Day, Absent, Missed Punch, Shift Violation
  graceTime           Int             @default(0) // Minutes
  penaltyTriggerAfter Int             @default(1) // e.g., 3 late marks
  penaltyType         String          // "Warning Only", "Deduct Salary", "Convert to Leave"
  penaltyValue        Float?          // Fixed Amount, Per Hour Deduction, Per Day Deduction
  shiftId             Int?
  shift               Shift?          @relation(fields: [shiftId], references: [id])
  frequency           String          @default("Daily") // Daily, Weekly, Monthly
  isActive            Boolean         @default(true)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  penaltyRecords      PenaltyRecord[]
}

model PenaltyConversion {
  id                Int      @id @default(autoincrement())
  penaltyType       String   // Late In, Early Out, etc.
  conversionCount   Int      // e.g., 3 (lates)
  leaveDeductionVal Float    // e.g., 0.5 (day)
  leaveTypeId       Int?
  leaveType         LeaveType? @relation(fields: [leaveTypeId], references: [id])
  maxLimit          Int?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PenaltyRecord {
  id                Int      @id @default(autoincrement())
  employeeId        Int
  employee          Employee @relation(fields: [employeeId], references: [id])
  ruleId            Int?
  rule              PenaltyRule? @relation(fields: [ruleId], references: [id])
  penaltyType       String
  date              DateTime
  shiftId           Int?
  shift             Shift?   @relation(fields: [shiftId], references: [id])
  reason            String?  @db.Text
  amountDeducted    Float?
  leaveDeducted     Float?
  status            String   @default("Pending") // Pending, Approved, Rejected, Applied
  approvedBy        Int?
  approvedAt        DateTime?
  rejectionReason   String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// -------------------------------------------------------------
// Company Gallery Module
// -------------------------------------------------------------

model GalleryAlbum {
  id           Int      @id @default(autoincrement())
  name         String
  description  String?  @db.Text
  eventId      Int?
  event        Event?   @relation(fields: [eventId], references: [id])
  branches     Json?    
  departments  Json?    
  visibility   String   @default("Public") // Public, Restricted
  coverImage   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  media        GalleryMedia[]
}

model GalleryMedia {
  id           Int      @id @default(autoincrement())
  albumId      Int
  album        GalleryAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
  url          String   @db.Text
  type         String   // Photo, Video, YouTube
  tags         String?  // comma separated or JSON
  description  String?  @db.Text
  uploadedBy   Int?
  likes        Int      @default(0)
  allowDownload Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// -------------------------------------------------------------
// Assets Setup Module
// -------------------------------------------------------------

model AssetIDSetting {
  id                   Int     @id @default(autoincrement())
  enableAutoGenerate   Boolean @default(true)
  prefix               String  @default("AST")
  includeCategoryCode  Boolean @default(true)
  serialType           String  @default("Auto") // Auto | Manual
  updateExisting       Boolean @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model AssetCategory {
  id               Int      @id @default(autoincrement())
  name             String   @unique
  code             String   @unique
  imageRequired    Boolean  @default(false)
  serialRequired   Boolean  @default(true)
  isHidden         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  assets           Asset[]
}

model Asset {
  id             Int            @id @default(autoincrement())
  assetCode      String?        @unique
  categoryId     Int
  category       AssetCategory  @relation(fields: [categoryId], references: [id])
  itemName       String
  brand          String?
  imageUrl       String?
  serialNo       String?
  macAddress     String?
  simNo          String?
  purchaseDate   DateTime?
  price          Float?
  vendor         String?
  custodianId    Int?
  custodian      Employee?      @relation(fields: [custodianId], references: [id])
  location       String?
  credentials    String?        @db.Text
  description    String?        @db.Text
  warrantyExpiry DateTime?
  depreciationRate Float?       @default(0)
  status         String         @default("Active") // Active | Scrapped | Missing | UnderMaintenance | Returned
  branchId       Int?
  branch         Branch?        @relation("BranchAssets", fields: [branchId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  history        AssetHistory[]
  maintenance    AssetMaintenance[]
  scrap          AssetScrap?
}

model AssetHistory {
  id        Int      @id @default(autoincrement())
  assetId   Int
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  action    String   // Assigned | Transferred | Maintenance | Scrapped | Created | Returned
  fromInfo  String?
  toInfo    String?
  doneBy    String?
  remark    String?  @db.Text
  createdAt DateTime @default(now())
}

model AssetScrap {
  id        Int      @id @default(autoincrement())
  assetId   Int      @unique
  asset     Asset    @relation(fields: [assetId], references: [id])
  reason    String   // Damaged | Old | Lost
  soldPrice Float?
  scrapDate DateTime
  scrapBy   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AssetMaintenance {
  id                  Int      @id @default(autoincrement())
  assetId             Int
  asset               Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  maintenanceType     String   // AMC | Repair | Service
  frequency           String   @default("Monthly") // Monthly | Quarterly | Yearly | OneTime
  vendorName          String?
  vendorContact       String?
  nextMaintenanceDate DateTime
  lastMaintenanceDate DateTime?
  completedDate       DateTime?
  amountSpent         Float?
  status              String   @default("Pending") // Pending | Completed | Missed
  notes               String?  @db.Text
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model AssetSetting {
  id               Int      @id @default(autoincrement())
  employeeId       Int      @unique
  employee         Employee @relation(fields: [employeeId], references: [id])
  viewScope        String   @default("Own") // Own | Department | All
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}


// -------------------------------------------------------------
// Employees Nominee Module
// -------------------------------------------------------------

model NominationType {
  id              Int       @id @default(autoincrement())
  name            String    @unique // PF, Insurance, Salary, Bonus
  description     String?   @db.Text
  allowMultiple   Boolean   @default(false)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  nominees        EmployeeNominee[]
}

model EmployeeNominee {
  id              Int       @id @default(autoincrement())
  employeeId      Int
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  nominationTypeId Int
  nominationType  NominationType @relation(fields: [nominationTypeId], references: [id], onDelete: Cascade)
  
  nomineeName     String
  relation        String    // Father / Mother / Spouse / Child / Other
  dob             DateTime? @db.Date
  aadharNumber    String    // Making this non-unique at DB level to prevent errors if husband/wife nominate same child, but we'll validate. Actually, user asked for it to be unique.
  mobileNo        String
  email           String?
  address         String?   @db.Text
  nomineePercentage Float

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([aadharNumber, employeeId]) // making sure same employee cannot add same person twice, but keeping global unique could be problematic.
}

// -------------------------------------------------------------
// Lost & Found Module
// -------------------------------------------------------------

model LostFoundItem {
  id               Int       @id @default(autoincrement())
  type             String    // 'Lost' or 'Found'
  itemName         String
  description      String?   @db.Text
  date             DateTime  // Lost Date or Found Date // can store both
  location         String    // Branch / Area or Handover Location
  photoUrl         String?
  reportedById     Int       // Employee who reported
  contactDetails   String?   // For 'Lost' type (or generic)
  status           String    @default("Open") // Open, Matched, Returned
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  reportedBy       Employee  @relation(fields: [reportedById], references: [id])
  claims           ItemClaim[]
}

model ItemClaim {
  id               Int       @id @default(autoincrement())
  itemId           Int
  claimedById      Int
  proofDescription String    @db.Text
  status           String    @default("Pending") // Pending, Approved, Rejected
  approvedById     Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  item             LostFoundItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  claimedBy        Employee      @relation("ClaimedBy", fields: [claimedById], references: [id])
  approvedBy       Employee?     @relation("ApprovedBy", fields: [approvedById], references: [id])
}
// -------------------------------------------------------------
// Survey Management System
// -------------------------------------------------------------

model Survey {
  id              Int              @id @default(autoincrement())
  title           String
  description     String?          @db.Text
  startDate       DateTime
  endDate         DateTime?
  targetAudience  String           @default("All Employees") // All, Branch, Department, Individual
  isAnonymous     Boolean          @default(false)
  sendReminder    Boolean          @default(true)
  autoClose       Boolean          @default(false)
  status          String           @default("Active") // Active, Inactive, Completed, Draft
  
  questions       SurveyQuestion[]
  responses       SurveyResponse[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model SurveyQuestion {
  id              Int              @id @default(autoincrement())
  surveyId        Int
  survey          Survey           @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  questionText    String           @db.Text
  questionType    String           @default("Text") // Text, Multiple Choice, Rating, Likert
  options         Json?            // For multiple choice options
  isRequired      Boolean          @default(true)
  order           Int              @default(0)

  answers         SurveyAnswer[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model SurveyResponse {
  id              Int              @id @default(autoincrement())
  surveyId        Int
  survey          Survey           @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  employeeId      Int?             // Null if anonymous
  employee        Employee?        @relation(fields: [employeeId], references: [id])
  submittedAt     DateTime         @default(now())

  answers         SurveyAnswer[]

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([surveyId, employeeId])
}

model SurveyAnswer {
  id              Int              @id @default(autoincrement())
  responseId      Int
  response        SurveyResponse   @relation(fields: [responseId], references: [id], onDelete: Cascade)
  questionId      Int
  question        SurveyQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answerText      String?          @db.Text
  rating          Int?
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}
// -------------------------------------------------------------
// Poll Management Module
// -------------------------------------------------------------

model Poll {
  id              Int           @id @default(autoincrement())
  question        String        @db.Text
  description     String?       @db.Text
  startDate       DateTime
  endDate         DateTime?
  targetAudience  String        @default("All Employees")
  isMultipleChoice Boolean      @default(false)
  isAnonymous     Boolean       @default(true)
  status          String        @default("Active") // Active, Closed, Upcoming
  
  options         PollOption[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model PollOption {
  id              Int           @id @default(autoincrement())
  pollId          Int
  poll            Poll          @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionText      String
  votes           Int           @default(0)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// -------------------------------------------------------------
// App Banner, LMS, Logs, and Settings Extensions
// -------------------------------------------------------------

model AppBanner {
  id           Int      @id @default(autoincrement())
  image        String?  @db.Text
  title        String
  type         String   // Image | Video | URL | Call
  active       Boolean  @default(true)
  clicks       Int      @default(0)
  views        Int      @default(0)
  schedule     String?
  actionValue  String?  @db.Text
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model LmsCourse {
  id              Int      @id @default(autoincrement())
  name            String
  category        String
  durationMinutes Int      @default(30)
  assignedCount   Int      @default(0)
  status          String   @default("Draft") // Draft | Published
  description     String?  @db.Text
  passingGrade    Int      @default(70)
  contentUrl      String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  progress        LmsCourseProgress[]
}

model LmsCourseProgress {
  id            Int       @id @default(autoincrement())
  courseId      Int
  course        LmsCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
  employeeId    Int?
  employeeName  String?
  progress      Int       @default(0)
  status        String    @default("Not Started") // Not Started | In Progress | Completed
  score         String?
  completedDate DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ActivityLog {
  id          Int      @id @default(autoincrement())
  dateTime    DateTime @default(now())
  user        String
  module      String
  action      String
  description String?  @db.Text
  ip          String?
  device      String?
  by          String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdminAccessRule {
  id                Int      @id @default(autoincrement())
  employeeName      String
  designation       String?
  parentModule      String
  submodule         String
  accessFor         String
  accessMode        String
  teamRequestNeeded Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model AdminPermissionSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppSettingsConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
