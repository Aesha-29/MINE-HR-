  updatedAt   DateTime @updatedAt
}


// -------------------------------------------------------------
// Template Module (Feature: Custom Reporting)
// -------------------------------------------------------------

model Template {
  id                    Int      @id @default(autoincrement())
  templateId            String   @unique @default(uuid())
  name                  String
  description           String?  @db.Text
  groupName             String?  // Comma-separated group names
  templateType          String   // Work Report, Visit, Expense, Equipment, Task
  
  // Settings
  allowMultiplePerShift Boolean  @default(false)
  requiredOnPunchIn     Boolean  @default(false)
  requiredOnPunchOut    String   @default("Optional") // Optional, Required
  needReportingPerson   Boolean  @default(false)
  
  status                String   @default("Active") // Active, Hidden
  
  questions             TemplateQuestion[]
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model TemplateQuestion {
  id                    Int      @id @default(autoincrement())
  templateId            Int
  template              Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  
  questionTitle         String
  placeholder           String?
  questionType          String   // Description, Radio Button, Checkbox, etc.
  isRequired            String   @default("No") // Yes, No, On Previous Question
  
  options               Json?    // For Radio, Checkbox, Dropdown options
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// -----------------------------------------------
// Product & Order Management Suite
// -----------------------------------------------

model Country {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  states       State[]
  distributors Distributor[]
}

model State {
  id        Int      @id @default(autoincrement())
  countryId Int
  country   Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  name      String
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  distributors Distributor[]
  retailers    Retailer[]
  cities       City[]

  @@unique([countryId, name])
}

model ProductCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?  @db.Text
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products        Product[]
  subCategories   ProductSubCategory[]
}

model ProductSubCategory {
  id          Int      @id @default(autoincrement())
  categoryId  Int
  category    ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name        String
  description String?  @db.Text
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]

  @@unique([categoryId, name])
}

model Product {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  categoryId      Int
  category        ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subCategoryId   Int?
  subCategory     ProductSubCategory? @relation(fields: [subCategoryId], references: [id], onDelete: SetNull)
  hsnCode         String?
  description     String?  @db.Text
  status          String   @default("Active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  variants        ProductVariant[]
  stocks          ProductStock[]
  stockLogs       StockLog[]
}

model ProductVariant {
  id                      Int      @id @default(autoincrement())
  productId               Int
  product                 Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantName             String
  sku                     String   @unique
  bulkType                String? // Carton, Box, Piece, etc.
  perBoxPiece             Int?
  retailerSellingPrice    Float
  mrp                     Float
  manufacturingCost       Float
  unit                    String? // kg, ltr, piece, etc.
  photo                   String?
  status                  String   @default("Active")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  stocks                  ProductStock[]
  stockLogs               StockLog[]

  @@unique([productId, sku])
}

model Distributor {
  id                Int      @id @default(autoincrement())
  name              String
  contactPerson     String?
  contactNumber     String?
  orderEmail        String?
  distributorEmail  String?
  countryId         Int?
  country           Country? @relation(fields: [countryId], references: [id], onDelete: SetNull)
  stateId           Int?
  state             State?   @relation(fields: [stateId], references: [id], onDelete: SetNull)
  city              String?
  type              String? // Whole Sale, Semi Whole Sale, etc.
  status            String   @default("Active")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  retailers Retailer[]
  productStocks ProductStock[]
  stockLogs     StockLog[]
  distributorAssignments DistributorAssignment[]

  @@unique([name, city])
}

model SuperDistributor {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  contactPerson   String?
  contactNumber   String?
  orderEmail      String?
  photo           String?
  status          String   @default("Active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Retailer {
  id              Int      @id @default(autoincrement())
  name            String
  contactNumber   String?
  distributorId   Int
  distributor     Distributor @relation(fields: [distributorId], references: [id], onDelete: Cascade)
  area            String?
  city            String
  stateId         Int?
  state           State?   @relation(fields: [stateId], references: [id], onDelete: SetNull)
  type            String? // Grocery Store, Super Market, etc.
  gst             String?
  status          String   @default("Active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([name, distributorId, city])
}

model DistributorAssignment {
  id           Int         @id @default(autoincrement())
  employeeId   Int
  employee     Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  distributorId Int
  distributor  Distributor @relation(fields: [distributorId], references: [id], onDelete: Cascade)

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([employeeId, distributorId])
  @@index([employeeId])
  @@index([distributorId])
}

model CustomerCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?  @db.Text
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subCategories CustomerSubCategory[]
}

model CustomerSubCategory {
  id               Int      @id @default(autoincrement())
  categoryId       Int
  category         CustomerCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name             String
  description      String?  @db.Text
  status           String   @default("Active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([categoryId, name])
}

model BeatPlan {
  id             Int      @id @default(autoincrement())
  employeeId     Int
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  weekDay        String   // Monday, Tuesday, etc.
  retailerCount  Int?
  city           String?
  status         String   @default("Active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model JobLocation {
  id           Int      @id @default(autoincrement())
  employeeId   Int      @unique
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  countries    String?  // JSON array of country IDs
  states       String?  // JSON array of state IDs
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model DailySalesAggregate {
  id             Int      @id @default(autoincrement())
  employeeId     Int
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  orderCount     Int      @default(0)
  totalQuantity  Int      @default(0)
  salesAmount    Float    @default(0)
  distributor    String?
  city           String?
  date           DateTime @db.Date
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([employeeId, date])
}

model Order {
  id               Int      @id @default(autoincrement())
  orderNo          String   @unique
  employeeId       Int
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  orderBy          String   // Storing name of the employee placing the order
  retailer         String
  distributor      String
  city             String?
  area             String?
  amount           Float
  quantity         Int
  unit             String?
  status           String   @default("Pending") // Pending, Approved, Rejected, Cancelled, Delivered
  dateTime         DateTime @default(now())
  location         String?
  outOfRange       String   @default("No") // "Yes" or "No"
  outOfRangeReason String?  @db.Text
  country          String?
  state            String?
  product          String

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model UnitMeasure {
  id        Int      @id @default(autoincrement())
  unitName  String   @unique
  symbol    String?
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductStock {
  id              Int      @id @default(autoincrement())
  productId       Int
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId       Int
  variant         ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  distributorId   Int?
  distributor     Distributor? @relation(fields: [distributorId], references: [id], onDelete: SetNull)
  availableStocks Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([variantId, distributorId])
}

model StockLog {
  id              Int      @id @default(autoincrement())
  type            String
  quantity        Int
  performBy       String
  orderId         String?
  productId       Int
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId       Int
  variant         ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  distributorId   Int?
  distributor     Distributor? @relation(fields: [distributorId], references: [id], onDelete: SetNull)
  stockDate       DateTime @db.Date
  stockTime       String?
  createdAt       DateTime @default(now())
}

// -----------------------------------------------
// Epic 2: Geolocation & Route Management Extension
// -----------------------------------------------

model City {
  id        Int      @id @default(autoincrement())
  name      String
  stateId   Int
  state     State    @relation(fields: [stateId], references: [id], onDelete: Cascade)
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  areas     Area[]
  routes    SalesRoute[]

  @@unique([stateId, name])
}

model Area {
  id        Int      @id @default(autoincrement())
  name      String
  cityId    Int
  city      City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  routes    SalesRoute[]

  @@unique([cityId, name])
}

model SalesRoute {
  id          Int      @id @default(autoincrement())
  routeName   String
  cityId      Int
  city        City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  areaId      Int
  area        Area     @relation(fields: [areaId], references: [id], onDelete: Cascade)
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employeeRoutes EmployeeRoute[]
}

model EmployeeRoute {
  id            Int        @id @default(autoincrement())
  routeId       Int
  route         SalesRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  employeeId    Int
  employee      Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  assignedDate  DateTime   @default(now())
  status        String     @default("Active")
}

// -------------------------------------------------------------
// Expense Module
// -------------------------------------------------------------

model ExpenseCategory {
  id                   Int       @id @default(autoincrement())
  categoryName         String    @unique
  expenseSlabType      String    // "Fixed" | "Slab Wise"
  type                 String    // "Fixed" | "Unit" | "Both"
  paymentMode          String?   // "Cash" | "Bank" | "Card" - default payment mode
  unitName             String?   // "KM", "Hours", "Days"
  unitPrice            Float?    // per unit cost
  amountType           String?   // "Fixed", "Variable"
  amount               Float?    // Max limit
  taxSlabId            Int?
  attachmentRequired   Boolean   @default(false)
  autoApproved         Boolean   @default(false)
  isVisitExpense       Boolean   @default(false)
  isTravelExpense      Boolean   @default(false)

  subCategories        ExpenseSubCategory[]
  assignments          VisitExpenseAssignment[]

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model ExpenseSubCategory {
  id                   Int       @id @default(autoincrement())
  categoryId           Int
  category             ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subCategoryName      String
  type                 String    // "Fixed" | "Unit" | "Both"
  paymentMode          String?
  unitName             String?
  unitPrice            Float?
  amountType           String?
  amount               Float?
  attachmentRequired   Boolean   @default(false)
  autoApproved         Boolean   @default(false)

  assignments          VisitExpenseAssignment[]

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([categoryId, subCategoryName])
}

model VisitExpenseAssignment {
  id                   Int       @id @default(autoincrement())
  employeeId           Int?      // Nullable if assigned to role
  employee             Employee? @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  role                 String?   // E.g., "Sales Staff", "Field Staff"
  categoryId           Int
  category             ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subCategoryId        Int?
  subCategory          ExpenseSubCategory? @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)
  
  isVisitExpense       Boolean   @default(false)
  isTravelExpense      Boolean   @default(false)
  limitAmount          Float?    // Max allowed amount
  dailyLimit           Float?    
  monthlyLimit         Float?
  startDate            DateTime? @db.Date
  endDate              DateTime? @db.Date
  status               String    @default("Active") // Active, Inactive

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model ExpenseSetting {
  id                   Int       @id @default(autoincrement())
  branchId             Int?
  branch               Branch?    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  departmentId         Int?
  department           Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  subDepartment        String?
  isExpenseEnabled     Boolean   @default(true)
  hideExpenseTitle     Boolean   @default(false)
  dayTypeOption        String?   // None, Half Day / Full Day, Working / Non-Working, Visit / Office
  allowBackdate        Boolean   @default(false)
  maxBackdateDays      Int?      @default(0)
  approvalRequired     Boolean   @default(true)
  autoApprove          Boolean   @default(false)

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([branchId, departmentId, subDepartment])
}

// ---------------------------------------------------------------------------
// ADVANCE PAYMENTS
// ---------------------------------------------------------------------------

model AdvanceSalary {
  id               Int      @id @default(autoincrement())
  employeeId       Int
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  department       String?
  salaryMonth      String   // e.g. "2026-03"
  givenDate        DateTime @db.Date
  
  amount           Float
  remainingAmount  Float
  givenMode        String   // e.g. "Cash", "Bank", "UPI"
  remark           String?  @db.Text
  attachment       String?  // URL/Path
  
  status           String   @default("Pending") // "Pending", "Paid", "Returned"

  createdBy        Int?     // User ID who created it
  returnByDate     DateTime? @db.Date // Optional due date

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  returns          AdvanceSalaryReturn[]
}

model AdvanceSalaryReturn {
  id               Int      @id @default(autoincrement())
  advanceId        Int
  advance          AdvanceSalary @relation(fields: [advanceId], references: [id], onDelete: Cascade)
  
  returnDate       DateTime @db.Date
  amount           Float
  adjustedInPayroll Boolean  @default(false)
  remark           String?  @db.Text

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model AdvanceSalaryRequest {
  id               Int      @id @default(autoincrement())
  employeeId       Int
  employee         Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  requestedAmount  Float
  reason           String?  @db.Text
  requestDate      DateTime @default(now())
  
  status           String   @default("Pending") // "Pending", "Approved", "Rejected"
  attachment       String?

  adminRemark      String?  @db.Text
  approvedBy       Int?
  approvalDate     DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// EXPENSE TEMPLATES & ENTRIES
// ---------------------------------------------------------------------------

model ExpenseTemplate {
  id                    Int      @id @default(autoincrement())
  templateName          String   @unique
  description           String?  @db.Text

  // Per expense-type configuration stored as JSON
  expenseTypes          Json     // Array of {type, dailyLimit, monthlyLimit, perClaimLimit, approvalRequired, autoApprovalLimit, attachmentRequired, billRequired, allowMultiplePerDay, restrictWithoutVisit, linkWith}

  status                String   @default("Active") // Active, Inactive

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  assignments           ExpenseTemplateAssignment[]
  entries               ExpenseEntry[]
}

model ExpenseTemplateAssignment {
  id           Int              @id @default(autoincrement())
  templateId   Int
  template     ExpenseTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)

  employeeId   Int?
  employee     Employee?        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  department   String?
  branch       String?

  assignedAt   DateTime         @default(now())
  status       String           @default("Active")

  @@index([employeeId])
  @@index([templateId])
}

model ExpenseEntry {
  id             Int              @id @default(autoincrement())
  employeeId     Int
  employee       Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  templateId     Int?
  template       ExpenseTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  expenseType    String           // Travel, Food, Stay, Misc, etc.
  amount         Float
  expenseDate    DateTime         @db.Date
  description    String?          @db.Text
  attachment     String?          // file path / URL
  linkWith       String?          // "Visit" | "Order" | "General"
  visitId        Int?
  orderId        Int?

  // Approval flow
  status         String           @default("Pending") // Pending, Approved, Rejected, Paid
  approvedBy     Int?
  approvedAt     DateTime?
  rejectedBy     Int?
  rejectedAt     DateTime?
  rejectionNote  String?          @db.Text

  // Payment
  paidBy         Int?
  paidAt         DateTime?
  paymentMode    String?          // Cash, Bank, UPI
  voucherNo      String?          // voucher reference

  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([employeeId, status])
  @@index([expenseDate])
}

model ExpenseAdvance {
  id              Int      @id @default(autoincrement())
  employeeId      Int
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  requestedAmount Float
  reason          String?  @db.Text

  // Approval
  status          String   @default("Pending") // Pending, Approved, Rejected
  approvedBy      Int?
  approvedAt      DateTime?
  adminRemark     String?  @db.Text

  // Usage
  usedAmount      Float    @default(0)
  remainingAmount Float    @default(0)
  paidAmount      Float    @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// -------------------------------------------------------------
// NEW MODULES: TASK, BALANCE SHEET, QUOTATION
// -------------------------------------------------------------

model TaskCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?  @db.Text
  status      String   @default("Active")
  
  tasks       Task[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TaskPriority {
  id          Int      @id @default(autoincrement())
  name        String   @unique // High, Medium, Low
  color       String?  // hex code
  level       Int      @default(1) // 1=highest
  
  tasks       Task[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id            Int           @id @default(autoincrement())
  title         String
  description   String?       @db.Text
  
  status        String        @default("Pending") // Pending, In Progress, Completed, Overdue
  
  categoryId    Int?
  category      TaskCategory? @relation(fields: [categoryId], references: [id])
  
  priorityId    Int?
  priority      TaskPriority? @relation(fields: [priorityId], references: [id])
  
  assignedToId  Int?
  assignedTo    Employee?     @relation("TaskAssignedTo", fields: [assignedToId], references: [id])
  
  createdBy     Int?          // Employee ID
  
  dueDate       DateTime?
  completedAt   DateTime?
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
}

model LedgerTransaction {
  id          Int      @id @default(autoincrement())
  date        DateTime @default(now())
  type        String   // e.g. "Sales Revenue", "Office Rent"
  category    String   // Income, Expense, Asset, Liability
  
  branchId    Int?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  
  amount      Float
  paymentMode String   // Bank, Cash, Card
  remark      String?  @db.Text
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model QuotationColumnConfig {
  id          Int      @id @default(autoincrement())
  columnName  String
  visible     Boolean  @default(true)
  sequence    Int      @default(0)
  customLabel String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([columnName])
}

// Update Employee relation for Tasks
